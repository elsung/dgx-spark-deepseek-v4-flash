#!/usr/bin/env bash
# serve-gb10 — llama.cpp / ik_llama.cpp server presets tuned for DGX Spark GB10 (128 GB unified).
# Unlike the 16 GB starter presets, EVERYTHING is fully GPU-resident: -ngl 999, NO -ncmoe offload,
# and generous context (memory is not the constraint here). OpenAI API on :8080.
#   ./serve-gb10 list
#   ./serve-gb10 gemma4-26b-mtp
set -euo pipefail
G="$HOME/LLMs/models/gguf"
LLAMA="$HOME/AI/llama.cpp/build/bin/llama-server"
IK="$HOME/AI/ik_llama.cpp/build/bin/llama-server"
PORT="${PORT:-8080}"; HOST="${HOST:-0.0.0.0}"
p="${1:-}"; shift || true
case "$p" in
  qwen3.5-9b)     BIN=$LLAMA; A=(-m "$G/Qwen3.5-9B-Q5KXL.gguf" --mmproj "$G/Qwen3.5-9B-Q5KXL.mmproj.gguf" -ngl 999 -fa on -c 131072 --parallel 8) ;;
  qwen3.5-9b-mtp) BIN=$LLAMA; A=(-m "$G/Qwen3.5-9B-MTP.gguf" -ngl 999 -fa on -c 32768 -np 1 --spec-type draft-mtp --spec-draft-n-max 2) ;;
  gemma4-12b)     BIN=$LLAMA; A=(-m "$G/Gemma4-12B-Q4KXL.gguf" --mmproj "$G/Gemma4-12B-Q4KXL.mmproj.gguf" --jinja -ngl 999 -fa on -c 131072 --parallel 8) ;;
  gemma4-26b)     BIN=$IK;    A=(-m "$G/Gemma4-26B-A4B-IQ4XS.gguf" -ngl 999 -fa 1 -ctk q8_0 -ctv q8_0 -c 65536 -ub 512 --parallel 8) ;;
  gemma4-26b-mtp) BIN=$IK;    A=(-m "$G/Gemma4-26B-A4B-IQ4XS.gguf" -md "$G/Gemma4-26B-A4B-IQ4XS.mtp.gguf" -ngld 999 -ngl 999 -fa 1 -ctk q8_0 -ctv q8_0 -c 32768 --spec-type mtp:n_max=4,p_min=0.0) ;;
  qwen3.6-27b)    BIN=$IK;    A=(-m "$G/Qwen3.6-27B-IQ4KS.gguf" -ngl 999 -fa 1 -ctk q8_0 -ctv q8_0 -c 131072 --parallel 4) ;;
  gemma4-31b-mtp) BIN=$IK;    A=(-m "$G/Gemma4-31B-Q3KS.gguf" -md "$G/Gemma4-31B-Q3KS.mtp.gguf" -ngld 999 -ngl 999 -fa 1 -ctk q8_0 -ctv q8_0 -c 32768 --spec-type mtp:n_max=4,p_min=0.0) ;;
  qwen3.6-35b)    BIN=$LLAMA; A=(-m "$G/Qwen3.6-35B-A3B-Q4KM.gguf" --mmproj "$G/Qwen3.6-35B-A3B-Q4KM.mmproj.gguf" --jinja -ngl 999 -fa on -c 65536 --parallel 4) ;;
  gemma3-27b)     BIN=$LLAMA; A=(-m "$G/Gemma3-27B-QAT-Q4_0.gguf" --mmproj "$G/Gemma3-27B-QAT-Q4_0.mmproj.gguf" -ngl 999 -fa on -c 32768 --parallel 4) ;;
  minimax-172b)   BIN=$LLAMA; A=(-m "$G/MiniMax-172B-Q3KS.gguf" -ngl 999 -fa on -c 65536 --parallel 2) ;;
  minimax-139b)   BIN=$LLAMA; A=(-m "$G/MiniMax-139B-Q3KM.gguf" -ngl 999 -fa on -c 65536 --parallel 2) ;;
  list|"") echo "presets: qwen3.5-9b qwen3.5-9b-mtp gemma4-12b gemma4-26b gemma4-26b-mtp qwen3.6-27b gemma4-31b-mtp qwen3.6-35b gemma3-27b minimax-172b minimax-139b"; exit 0;;
  *) echo "unknown preset '$p' — './serve-gb10 list'"; exit 1;;
esac
echo ">> serving '$p' on http://$HOST:$PORT  (Ctrl-C to stop)"
exec "$BIN" "${A[@]}" --host "$HOST" --port "$PORT" "$@"
